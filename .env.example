# Local development env vars. Copy to `.env` and fill in real values.
# Railway injects its own values in production — `.env` is gitignored.

# === Admin login ===
# Password used at /api/admin/login. Change to anything for local dev.
ADMIN_PASSWORD=admin

# === Database ===
# Local Postgres via Docker (matches the docker run command in the README).
# Bound to host port 5433 so it doesn't clash with any other Postgres you
# might already be running on the default 5432.
#   docker run -d --name ballrace-pg -p 5433:5432 -e POSTGRES_PASSWORD=dev -v ballrace_pg_data:/var/lib/postgresql/data postgres:16
DATABASE_URL=postgres://postgres:dev@localhost:5433/postgres

# === Cloudflare R2 (image storage) ===
# Leave blank to fall back to base64 (uploads still work, just heavier).
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# === Misc ===
# PORT defaults to 3001 if unset.
# PORT=3001
